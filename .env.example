# 复制为 .env 并填入真实值（.env 已在 .gitignore 中）

# AgentRun API / CLI / tmux 默认走 OpenRouter。
# API profile:
# - api-openrouter-openai-glm-5.1      -> https://openrouter.ai/api/v1/chat/completions
# - api-openrouter-anthropic-glm-5.1   -> https://openrouter.ai/api/v1/messages
OPENROUTER_API_KEY=<填写 OpenRouter API Key>
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=z-ai/glm-5.1

# 可选：OpenRouter app attribution headers。
OPENROUTER_HTTP_REFERER=http://localhost
OPENROUTER_TITLE=agent-runtime

# CLI / tmux runtime 会在执行前从 OPENROUTER_API_KEY 导出：
# - codex: OPENAI_API_KEY / OPENAI_BASE_URL / OPENAI_MODEL
# - claude: ANTHROPIC_AUTH_TOKEN / ANTHROPIC_BASE_URL / ANTHROPIC_MODEL
