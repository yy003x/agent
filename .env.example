# 复制为 .env 并填入真实值（.env 已在 .gitignore 中）

# === 多模型后端 smoke：python3 scripts/model_backend_smoke.py --prompt "你好，介绍下自己" ===
# 阿里云百炼 / DashScope Qwen（同一个 key 可测文本与视觉模型；按实际模型名修改）
DASHSCOPE_API_KEY=<填写 DashScope API Key>
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_TEXT_MODEL=qwen3.6-plus
DASHSCOPE_VISION_MODEL=qwen-vl-max
ALIYUN_QWEN_MODEL_1=qwen-plus
ALIYUN_QWEN_MODEL_2=qwen-vl-max

# OpenRouter
OPENROUTER_API_KEY=<填写 OpenRouter API Key>
OPENROUTER_BASE_URL=https://openrouter.ai/api
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_HTTP_REFERER=http://localhost
OPENROUTER_TITLE=agent-model-test

# 智谱 BigModel
ZHIPUAI_API_KEY=<填写 ZhipuAI API Key>
ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
ZHIPUAI_MODEL=glm-4-flash

# Runtime API providers（LLM API backend 可填 openai / anthropic / deepseek）
AGENT_WORKBENCH_LLM_API_BACKEND=deepseek
OPENAI_API_KEY=<填写 OpenAI API Key>
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=
ANTHROPIC_API_KEY=<填写 Anthropic API Key>
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-haiku-latest
ANTHROPIC_MAX_TOKENS=2048
DEEPSEEK_API_KEY=<填写 DeepSeek API Key>
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 可选：模型覆盖（默认见 content_runtime.py 顶部常量）
# VISION_MODEL=claude-haiku-4-5-20251001   # 图片/帧 caption（高频，默认用 haiku 省成本）
# TEXT_MODEL=claude-opus-4-8               # 预留：文案生成脚本化后使用；当前由 AI 大脑 inline 生成

# 可选：知识库模型（默认见 04-knowledge-base.md）
# EMBED_MODEL=BAAI/bge-small-zh-v1.5       # 向量模型（中文，512 维）
# RERANK_MODEL=BAAI/bge-reranker-base      # 精排 cross-encoder
# EMBED_DEVICE=mps                         # mps | cpu（M1 默认 mps，回退 cpu）
# HF_ENDPOINT=https://hf-mirror.com        # HuggingFace 镜像（可选，加速首次下载）
