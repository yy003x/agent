# 复制为 .env 并填入真实值（.env 已在 .gitignore 中）

# 必填：Claude API Key（文案生成 + 图片/视频 caption）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# 可选：模型覆盖（默认见 content_runtime.py 顶部常量）
# VISION_MODEL=claude-haiku-4-5-20251001   # 图片/帧 caption（高频，默认用 haiku 省成本）
# TEXT_MODEL=claude-opus-4-8               # 预留：文案生成脚本化后使用；当前由 AI 大脑 inline 生成

# 可选：知识库模型（默认见 04-knowledge-base.md）
# EMBED_MODEL=BAAI/bge-small-zh-v1.5       # 向量模型（中文，512 维）
# RERANK_MODEL=BAAI/bge-reranker-base      # 精排 cross-encoder
# EMBED_DEVICE=mps                         # mps | cpu（M1 默认 mps，回退 cpu）
# HF_ENDPOINT=https://hf-mirror.com        # HuggingFace 镜像（可选，加速首次下载）
