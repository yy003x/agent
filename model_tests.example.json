      "api_key_env": "DASHSCOPE_API_KEY",
      "model": "qwen-plus",
      "temperature": 0.7
    },
    {
      "name": "aliyun-qwen-2",
      "provider": "aliyun",
      "url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "api_key_env": "DASHSCOPE_API_KEY",
      "model": "qwen-vl-max",
      "temperature": 0.7
    },
    {
