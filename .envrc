# Local development environment for direnv.
dotenv_if_exists .env

export AGENT_ROOT="$PWD"

case ":${PYTHONPATH:-}:" in
  *":$AGENT_ROOT:"*) ;;
  *) export PYTHONPATH="$AGENT_ROOT${PYTHONPATH:+:$PYTHONPATH}" ;;
esac

export AGENT_CACHE_HOME="${AGENT_CACHE_HOME:-$AGENT_ROOT/runs/cache}"
export XDG_CACHE_HOME="$AGENT_CACHE_HOME"
export PYTHONPYCACHEPREFIX="${AGENT_PYTHONPYCACHEPREFIX:-$AGENT_CACHE_HOME/pycache}"
mkdir -p "$XDG_CACHE_HOME" "$PYTHONPYCACHEPREFIX"

export AGENT_WORKBENCH_CHAT_RUNTIME="${AGENT_WORKBENCH_CHAT_RUNTIME:-codex_cli}"
export AGENT_WORKBENCH_DEFAULT_RUNTIME="${AGENT_WORKBENCH_DEFAULT_RUNTIME:-codex_cli}"
export AGENT_WORKBENCH_CODEX_NO_ALT_SCREEN="${AGENT_WORKBENCH_CODEX_NO_ALT_SCREEN:-1}"
